; Test closures in while share the outer loop variable

(var f0 nil)
(var f1 nil)
(var f2 nil)
(var i 0)

(while (< i 3)
  (block
    (if (= i 0) (set f0 (lambda () i)) nil)
    (if (= i 1) (set f1 (lambda () i)) nil)
    (if (= i 2) (set f2 (lambda () i)) nil)
    (set i (+ i 1))))

(vector (f0) (f1) (f2))

; Expect: (3 3 3)
